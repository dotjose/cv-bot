# OpenRouter (required for API + ingestion)
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# Optional (OpenRouter rankings / attribution)
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=cv-bot
# Transient OpenRouter failures (429 / 5xx / network)
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_BASE_MS=400

# Qdrant (required for API + ingestion)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# Must match the embedding model output size (text-embedding-3-small → 1536)
QDRANT_VECTOR_SIZE=1536

# Retrieval
RAG_TOP_K=6
RAG_PREFETCH=24

# API CORS (browser origin or *)
CORS_ORIGIN=*

# Next.js static site → API
NEXT_PUBLIC_API_URL=http://localhost:8787

# FastAPI (apps/backend): shared libs live in repo packages/ — path is set in app/_monorepo_path.py